{
  "appId": "com.zeus.widgetpanel",
  "productName": "Widget Panel",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "main.js",
    "preload.js",
    "store.js",
    "assets/**/*",
    "renderer/dist/**/*"
  ],
  "extraResources": [
    {
      "from": "native/bin",
      "to": "native/bin",
      "filter": ["*.exe", "*.dll"]
    }
  ],
  "win": {
    "target": "nsis"
  },
  "nsis": {
    "oneClick": true,
    "perMachine": false
  }
}
